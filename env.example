# ─── Airtable ────────────────────────────────────────────────────────────────
# Found in your Airtable account under: Account → API
AIRTABLE_API_KEY=
# Found in the URL of your base: airtable.com/{BASE_ID}/...
AIRTABLE_BASE_ID=

# ─── Africa's Talking (SMS) ──────────────────────────────────────────────────
# https://account.africastalking.com
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_SENDER_ID=AcaciaVelds
# The admin phone that receives SMS alerts, e.g. +254712345678
ADMIN_PHONE=

# ─── WhatsApp ────────────────────────────────────────────────────────────────
# International format without +, e.g. 254712345678
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ─── Optional: YouTube hero video ────────────────────────────────────────────
# The video ID from the URL: youtube.com/watch?v={VIDEO_ID}
NEXT_PUBLIC_YOUTUBE_VIDEO_ID=

# ─── Site URL (used for Open Graph & sitemap) ────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://acaciavelds.com
